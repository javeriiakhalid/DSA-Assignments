import java.util.*;  

public class DoublyList {

    // Node class
    static class Node {
        int data;
        Node prev, next;

        Node(int d) {
            data = d;
            prev = next = null;
        }
    }

    Node head;

    // Function to print list in backward direction
    void printBackward() {

        // Step 1: go to last node
        Node temp = head;
        while (temp.next != null) {
            temp = temp.next;
        }

        // Step 2: traverse backward using prev
        System.out.print("Backward Traversal: ");
        while (temp != null) {
            System.out.print(temp.data + " <-> ");
            temp = temp.prev;
        }
        System.out.println("null");
    }

    public static void main(String[] args) {

        DoublyList list = new DoublyList();

        // Creating nodes
        list.head = new Node(10);
        Node second = new Node(20);
        Node third = new Node(30);

        // Linking nodes
        list.head.next = second;
        second.prev = list.head;

        second.next = third;
        third.prev = second;

        // Backward traversal
        list.printBackward();
    }
}
