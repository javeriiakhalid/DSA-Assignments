import java.util.*;  

public class DoublyList {

    // Node class
    static class Node {
        int data;
        Node prev, next;

        Node(int d) {
            data = d;
            prev = next = null;
        }
    }

    Node head;

    // Function to print list in forward direction
    void printForward() {
        Node temp = head;

        System.out.print("Forward Traversal: ");
        while (temp != null) {
            System.out.print(temp.data + " <-> ");
            temp = temp.next;
        }
        System.out.println("null");
    }

    public static void main(String[] args) {

        DoublyList list = new DoublyList();

        // Creating doubly linked list manually
        list.head = new Node(10);
        Node second = new Node(20);
        Node third = new Node(30);

        // Linking nodes
        list.head.next = second;
        second.prev = list.head;

        second.next = third;
        third.prev = second;

        // Forward traversal
        list.printForward();
    }
}
